# # Base URL for the application under test
# BASE_URL=xyz

# # API base URL (can be same as BASE_URL or different)
# API_BASE_URL= webURL

# # Test user credentials
# USERNAME=user
# PASSWORD=user123

# # Path to store authentication state (session/cookies)
# AUTH_STATE_PATH=auth/user.json

# # Default timeout for test operations (in milliseconds)
# DEFAULT_TIMEOUT=30000
